{
  "name": "anchr",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch run src/server.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test src/",
    "test:e2e": "docker compose up -d && NOSTR_RELAYS=ws://localhost:7777 bun test e2e/",
    "test:all": "docker compose up -d && NOSTR_RELAYS=ws://localhost:7777 bun test src/ e2e/",
    "demo": "docker compose up -d && NOSTR_RELAYS=ws://localhost:7777 bun run scripts/demo.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@cashu/cashu-ts": "^3.5.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@noble/hashes": "^2.0.1",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.5",
    "lucide-react": "^0.577.0",
    "nostr-tools": "^2.23.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  }
}
